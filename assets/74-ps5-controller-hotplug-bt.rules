# Hefesto — FEAT-HOTPLUG-BT-01 — abre a GUI ao parear o DualSense via Bluetooth.
#
# Diferença vs 73-ps5-controller-hotplug.rules (USB):
# Pareamento Bluetooth não gera ACTION=="add" no SUBSYSTEM=="usb". O
# kernel cria um nó em /dev/hidrawN via hid-playstation sobre L2CAP, e
# o evento correspondente é ACTION=="add" SUBSYSTEM=="hidraw".
#
# KERNELS bate o padrão `0005:054C:PID.*` — 0005 = BUS_BLUETOOTH, 054C =
# vendor Sony, PID = 0CE6 (DualSense) ou 0DF2 (DualSense Edge). O sufixo
# varia por sessão de pareamento; por isso o wildcard .*.
#
# Estratégia: mesma unit do USB (hefesto-dualsense4unix-gui-hotplug.service). O
# launcher usa single_instance (BUG-TRAY-SINGLE-FLASH-01, "primeira vence")
# → GUI aberta = traz ao foco; GUI fechada = sobe. Idempotente.
#
# Verificação: após parear, confirmar o KERNELS real com
#   udevadm info -a /dev/hidrawN | grep KERNELS
# Se o sufixo do PID diferir entre kernels, adicionar variante aqui.
#
# Arquivo companheiro: assets/hefesto-dualsense4unix-gui-hotplug.service.

ACTION=="add", SUBSYSTEM=="hidraw", KERNELS=="0005:054C:0CE6.*", TAG+="systemd", ENV{SYSTEMD_USER_WANTS}="hefesto-dualsense4unix-gui-hotplug.service"
ACTION=="add", SUBSYSTEM=="hidraw", KERNELS=="0005:054C:0DF2.*", TAG+="systemd", ENV{SYSTEMD_USER_WANTS}="hefesto-dualsense4unix-gui-hotplug.service"
