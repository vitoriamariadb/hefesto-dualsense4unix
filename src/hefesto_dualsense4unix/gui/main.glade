<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk+" version="3.24"/>

  <object class="GtkAdjustment" id="lightbar_brightness_adj">
    <property name="lower">0</property>
    <property name="upper">100</property>
    <property name="step-increment">1</property>
    <property name="page-increment">10</property>
    <property name="value">100</property>
  </object>

  <!-- FEAT-RUMBLE-POLICY-01: slider de intensidade global. 0-200% porque acima
       de 100% AMPLIFICA o que o jogo pediu — é a razão de existir da faixa
       (BUG-RUMBLE-CUSTOM-MULT-CAP-01).
       HARM-19: o teto passou a ter UM dono — `profiles.schema.
       RUMBLE_CUSTOM_MULT_MAX` (2.0). Eram três: 2.0 no schema, 1.0 no handler
       `rumble.policy_custom` e 200% aqui; de 101% em diante a usuária levava um
       erro de validação que a aba reportava como "daemon offline?". Mexeu no
       teto? Mexa no schema — este slider é `mult * 100`. -->
  <object class="GtkAdjustment" id="rumble_policy_adj">
    <property name="lower">0</property>
    <property name="upper">200</property>
    <property name="step-increment">1</property>
    <property name="page-increment">10</property>
    <property name="value">70</property>
  </object>

  <object class="GtkAdjustment" id="rumble_weak_adj">
    <property name="lower">0</property>
    <property name="upper">255</property>
    <property name="step-increment">1</property>
    <property name="page-increment">10</property>
    <property name="value">0</property>
  </object>

  <object class="GtkAdjustment" id="rumble_strong_adj">
    <property name="lower">0</property>
    <property name="upper">255</property>
    <property name="step-increment">1</property>
    <property name="page-increment">10</property>
    <property name="value">0</property>
  </object>

  <object class="GtkAdjustment" id="profile_priority_adj">
    <property name="lower">0</property>
    <property name="upper">100</property>
    <property name="step-increment">5</property>
    <property name="page-increment">10</property>
    <property name="value">0</property>
  </object>

  <object class="GtkAdjustment" id="mouse_speed_adj">
    <property name="lower">1</property>
    <property name="upper">12</property>
    <property name="step-increment">1</property>
    <property name="page-increment">2</property>
    <property name="value">6</property>
  </object>

  <object class="GtkAdjustment" id="mouse_scroll_speed_adj">
    <property name="lower">1</property>
    <property name="upper">5</property>
    <property name="step-increment">1</property>
    <property name="page-increment">1</property>
    <property name="value">1</property>
  </object>

  <object class="GtkWindow" id="main_window">
    <property name="title" translatable="yes">Hefesto - Dualsense4Unix</property>
    <property name="default-width">1100</property>
    <property name="default-height">680</property>
    <!-- Largura/altura mínimas: garantem o espaço do rodapé (4 botões) em janela
         flutuante. Sob tiling do COSMIC (que ignora min-size) o GtkFlowBox do
         rodapé + os ScrolledWindow das abas são a rede de segurança. BUG-FOOTER-CORTADO. -->
    <property name="width-request">760</property>
    <property name="height-request">560</property>
    <signal name="delete-event" handler="on_window_delete_event"/>
    <child>
      <object class="GtkBox" id="root_box">
        <property name="orientation">vertical</property>
        <property name="spacing">0</property>

        <!-- Banner: logo + wordmark + subtitle, status de conexao no canto direito -->
        <child>
          <object class="GtkBox" id="header_bar">
            <property name="orientation">horizontal</property>
            <property name="spacing">14</property>
            <property name="margin-top">10</property>
            <property name="margin-bottom">8</property>
            <property name="margin-start">14</property>
            <property name="margin-end">14</property>
            <child>
              <object class="GtkImage" id="app_logo">
                <property name="valign">center</property>
              </object>
              <packing><property name="expand">False</property></packing>
            </child>
            <child>
              <object class="GtkBox" id="header_text_box">
                <property name="orientation">vertical</property>
                <property name="spacing">2</property>
                <property name="valign">center</property>
                <child>
                  <object class="GtkLabel" id="app_wordmark">
                    <property name="label" translatable="yes">&lt;span size="xx-large" weight="bold"&gt;Hefesto - Dualsense4Unix&lt;/span&gt;</property>
                    <property name="use-markup">True</property>
                    <property name="xalign">0</property>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>
                <child>
                  <object class="GtkLabel" id="app_subtitle">
                    <property name="label" translatable="yes">&lt;span size="small" foreground="#888"&gt;daemon de gatilhos adaptativos para DualSense&lt;/span&gt;</property>
                    <property name="use-markup">True</property>
                    <property name="xalign">0</property>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>
              </object>
              <packing><property name="expand">True</property><property name="fill">True</property></packing>
            </child>
            <child>
              <object class="GtkLabel" id="header_connection">
                <property name="label" translatable="yes">&lt;span foreground="#d33"&gt; Controle Desconectado&lt;/span&gt;</property>
                <property name="use-markup">True</property>
                <property name="valign">center</property>
              </object>
              <packing><property name="expand">False</property><property name="pack-type">end</property></packing>
            </child>
          </object>
          <packing><property name="expand">False</property></packing>
        </child>

        <child>
          <object class="GtkSeparator"/>
          <packing><property name="expand">False</property></packing>
        </child>

        <!-- Notebook com abas -->
        <child>
          <object class="GtkNotebook" id="main_notebook">
            <property name="scrollable">True</property>
            <property name="margin">8</property>

            <!-- ABA INICIO (FEAT-GUI-HOME-TAB-01): comutador de modo do sistema
                 + cards por controle + desligar de verdade. Conteudo dinamico
                 montado em install_home_tab() (home_actions.py). -->
            <child>
              <object class="GtkBox" id="tab_home_box">
                <property name="orientation">vertical</property>
                <property name="spacing">12</property>
                <property name="margin">12</property>
              </object>
            </child>
            <child type="tab">
              <object class="GtkLabel" id="tab_home_label">
                <property name="label" translatable="yes">Início</property>
              </object>
            </child>

            <!-- ABA STATUS -->
            <child>
              <object class="GtkBox" id="tab_status_box">
                <property name="orientation">vertical</property>
                <property name="spacing">12</property>
                <property name="margin">12</property>

                <!-- UX-03: banner de degradação do gamepad virtual (máscara
                     DualSense no backend uinput). Texto e visibilidade vêm do
                     StatusActionsMixin._refresh_vpad_banner; invisível por
                     padrão e imune ao show_all (no-show-all). -->
                <child>
                  <object class="GtkLabel" id="status_vpad_banner">
                    <property name="visible">False</property>
                    <property name="no-show-all">True</property>
                    <property name="wrap">True</property>
                    <property name="xalign">0</property>
                    <style><class name="hefesto-dualsense4unix-status-warn"/></style>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>

                <!-- GUI-05 item 3: banner "jogo sem wrapper" (honestidade do
                     dedup). Texto e visibilidade vêm do
                     StatusActionsMixin._refresh_wrapper_banner; invisível por
                     padrão e imune ao show_all (no-show-all). -->
                <child>
                  <object class="GtkLabel" id="status_wrapper_banner">
                    <property name="visible">False</property>
                    <property name="no-show-all">True</property>
                    <property name="wrap">True</property>
                    <property name="xalign">0</property>
                    <style><class name="hefesto-dualsense4unix-status-warn"/></style>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>

                <child>
                  <object class="GtkFrame" id="frame_status_estado">
                    <property name="label" translatable="yes">Estado</property>
                    <child>
                      <object class="GtkGrid" id="status_grid">
                        <property name="row-spacing">6</property>
                        <property name="column-spacing">12</property>
                        <property name="margin">12</property>
                        <style><class name="hefesto-dualsense4unix-card"/></style>

                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">Conexão:</property>
                            <property name="xalign">1</property>
                          </object>
                          <packing><property name="left-attach">0</property><property name="top-attach">0</property></packing>
                        </child>
                        <child>
                          <object class="GtkLabel" id="status_connection">
                            <property name="label" translatable="yes">Consultando...</property>
                            <property name="xalign">0</property>
                          </object>
                          <packing><property name="left-attach">1</property><property name="top-attach">0</property></packing>
                        </child>

                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">Transporte:</property>
                            <property name="xalign">1</property>
                          </object>
                          <packing><property name="left-attach">0</property><property name="top-attach">1</property></packing>
                        </child>
                        <child>
                          <object class="GtkLabel" id="status_transport">
                            <property name="label">—</property>
                            <property name="xalign">0</property>
                          </object>
                          <packing><property name="left-attach">1</property><property name="top-attach">1</property></packing>
                        </child>

                        <child>
                          <!-- STATUS-02: id p/ a mixin esconder a linha junto
                               com a barra quando há 2+ controles (cada card
                               tem a própria bateria). -->
                          <object class="GtkLabel" id="status_battery_caption">
                            <property name="label" translatable="yes">Bateria:</property>
                            <property name="xalign">1</property>
                          </object>
                          <packing><property name="left-attach">0</property><property name="top-attach">2</property></packing>
                        </child>
                        <child>
                          <object class="GtkProgressBar" id="status_battery_bar">
                            <property name="show-text">True</property>
                            <property name="text">— %</property>
                            <property name="hexpand">True</property>
                          </object>
                          <packing><property name="left-attach">1</property><property name="top-attach">2</property></packing>
                        </child>

                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">Perfil ativo:</property>
                            <property name="xalign">1</property>
                          </object>
                          <packing><property name="left-attach">0</property><property name="top-attach">3</property></packing>
                        </child>
                        <child>
                          <object class="GtkLabel" id="status_active_profile">
                            <property name="label" translatable="yes">Nenhum</property>
                            <property name="xalign">0</property>
                          </object>
                          <packing><property name="left-attach">1</property><property name="top-attach">3</property></packing>
                        </child>

                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">Hefesto:</property>
                            <property name="xalign">1</property>
                          </object>
                          <packing><property name="left-attach">0</property><property name="top-attach">4</property></packing>
                        </child>
                        <child>
                          <object class="GtkLabel" id="status_daemon">
                            <property name="label" translatable="yes">Consultando...</property>
                            <property name="xalign">0</property>
                          </object>
                          <packing><property name="left-attach">1</property><property name="top-attach">4</property></packing>
                        </child>
                      </object>
                    </child>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>

                <!-- STATUS-02: um card por controle (ControllerCard, montado
                     por código em status_actions._sync_status_cards). Os
                     frames fixos "Gatilhos"/"Sticks e botões" (singletons do
                     primário) saíram — cada card carrega as próprias barras
                     L2/R2, sticks e glyphs, pintados na cor da lightbar
                     DAQUELE controle. Rolagem só vertical (nunca horizontal);
                     sem controle nenhum o box fica vazio e o fallback offline
                     do frame Estado responde (UI-STATUS-OFFLINE-FALLBACK-01). -->
                <child>
                  <object class="GtkScrolledWindow" id="status_players_scroll">
                    <property name="hscrollbar-policy">never</property>
                    <property name="vscrollbar-policy">automatic</property>
                    <property name="shadow-type">none</property>
                    <property name="propagate-natural-height">True</property>
                    <child>
                      <object class="GtkViewport">
                        <property name="shadow-type">none</property>
                        <child>
                          <object class="GtkBox" id="status_players_slot">
                            <property name="orientation">vertical</property>
                            <property name="spacing">12</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                  <packing><property name="expand">True</property><property name="fill">True</property></packing>
                </child>
              </object>
            </child>
            <child type="tab">
              <object class="GtkLabel"><property name="label" translatable="yes">Status</property></object>
            </child>

            <!-- ABA TRIGGERS -->
            <child>
              <object class="GtkBox" id="tab_triggers_box">
                <property name="orientation">horizontal</property>
                <property name="spacing">12</property>
                <property name="margin">12</property>

                <!-- Coluna L2 -->
                <child>
                  <object class="GtkFrame">
                    <property name="label" translatable="yes">L2 (gatilho esquerdo)</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">8</property>
                        <property name="margin">12</property>

                        <child>
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <property name="spacing">8</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="label" translatable="yes">Modo:</property>
                              </object>
                              <packing><property name="expand">False</property></packing>
                            </child>
                            <!-- FEAT-DSX-COMBO-TO-SEGMENTED-01: slot do SegmentedSelector
                                 (botões segmentados, sem popup; imune ao bug do cosmic-comp).
                                 O combo de modos era fechado no clique pelo compositor. Os
                                 itens (PRESETS) e o handler "changed" são ligados no código
                                 (triggers_actions.install_triggers_tab). -->
                            <child>
                              <object class="GtkBox" id="trigger_left_mode_slot">
                                <property name="orientation">horizontal</property>
                                <property name="hexpand">True</property>
                              </object>
                              <packing><property name="expand">True</property></packing>
                            </child>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>

                        <child>
                          <object class="GtkBox" id="trigger_left_preset_row">
                            <property name="orientation">horizontal</property>
                            <property name="spacing">8</property>
                            <property name="visible">False</property>
                            <property name="no-show-all">True</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="label" translatable="yes">Efeito pronto:</property>
                                <property name="visible">True</property>
                              </object>
                              <packing><property name="expand">False</property></packing>
                            </child>
                            <child>
                              <!-- FEAT-DSX-COMBO-TO-SEGMENTED-01: slot do preset (segmentado,
                                   sem popup — imune ao bug de foco do cosmic-comp). -->
                              <object class="GtkBox" id="trigger_left_preset_slot">
                                <property name="hexpand">True</property>
                                <property name="visible">True</property>
                              </object>
                              <packing><property name="expand">True</property></packing>
                            </child>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>

                        <child>
                          <object class="GtkLabel" id="trigger_left_desc">
                            <property name="label"></property>
                            <property name="xalign">0</property>
                            <property name="wrap">True</property>
                            <property name="margin-bottom">4</property>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>

                        <child>
                          <object class="GtkScrolledWindow">
                            <property name="hscrollbar-policy">never</property>
                            <property name="vscrollbar-policy">automatic</property>
                            <property name="min-content-height">220</property>
                            <property name="vexpand">True</property>
                            <child>
                              <object class="GtkBox" id="trigger_left_params_box">
                                <property name="orientation">vertical</property>
                                <property name="spacing">4</property>
                              </object>
                            </child>
                          </object>
                          <packing><property name="expand">True</property><property name="fill">True</property></packing>
                        </child>

                        <child>
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <property name="spacing">8</property>
                            <property name="homogeneous">True</property>
                            <child>
                              <object class="GtkButton" id="trigger_left_apply">
                                <property name="label" translatable="yes">Aplicar em L2</property>
                                <signal name="clicked" handler="on_trigger_left_apply"/>
                              <child internal-child="accessible">
                                <object class="AtkObject">
                                  <property name="AtkObject::accessible-name" translatable="yes">Aplicar gatilho adaptativo no L2</property>
                                  <property name="AtkObject::accessible-description" translatable="yes">Envia configuracao do gatilho esquerdo ao controle</property>
                                </object>
                              </child>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="trigger_left_reset">
                                <property name="label" translatable="yes">Desligar</property>
                                <signal name="clicked" handler="on_trigger_left_reset"/>
                              <child internal-child="accessible">
                                <object class="AtkObject">
                                  <property name="AtkObject::accessible-name" translatable="yes">Desligar gatilho L2</property>
                                  <property name="AtkObject::accessible-description" translatable="yes">Restaura L2 ao modo Off (sem resistencia)</property>
                                </object>
                              </child>
                              </object>
                            </child>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>
                      </object>
                    </child>
                  </object>
                  <packing><property name="expand">True</property><property name="fill">True</property></packing>
                </child>

                <!-- Coluna R2 -->
                <child>
                  <object class="GtkFrame">
                    <property name="label" translatable="yes">R2 (gatilho direito)</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">8</property>
                        <property name="margin">12</property>

                        <child>
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <property name="spacing">8</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="label" translatable="yes">Modo:</property>
                              </object>
                              <packing><property name="expand">False</property></packing>
                            </child>
                            <!-- FEAT-DSX-COMBO-TO-SEGMENTED-01: slot do SegmentedSelector
                                 (espelha o lado esquerdo; ver trigger_left_mode_slot). -->
                            <child>
                              <object class="GtkBox" id="trigger_right_mode_slot">
                                <property name="orientation">horizontal</property>
                                <property name="hexpand">True</property>
                              </object>
                              <packing><property name="expand">True</property></packing>
                            </child>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>

                        <child>
                          <object class="GtkBox" id="trigger_right_preset_row">
                            <property name="orientation">horizontal</property>
                            <property name="spacing">8</property>
                            <property name="visible">False</property>
                            <property name="no-show-all">True</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="label" translatable="yes">Efeito pronto:</property>
                                <property name="visible">True</property>
                              </object>
                              <packing><property name="expand">False</property></packing>
                            </child>
                            <child>
                              <!-- FEAT-DSX-COMBO-TO-SEGMENTED-01: slot do preset (segmentado). -->
                              <object class="GtkBox" id="trigger_right_preset_slot">
                                <property name="hexpand">True</property>
                                <property name="visible">True</property>
                              </object>
                              <packing><property name="expand">True</property></packing>
                            </child>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>

                        <child>
                          <object class="GtkLabel" id="trigger_right_desc">
                            <property name="label"></property>
                            <property name="xalign">0</property>
                            <property name="wrap">True</property>
                            <property name="margin-bottom">4</property>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>

                        <child>
                          <object class="GtkScrolledWindow">
                            <property name="hscrollbar-policy">never</property>
                            <property name="vscrollbar-policy">automatic</property>
                            <property name="min-content-height">220</property>
                            <property name="vexpand">True</property>
                            <child>
                              <object class="GtkBox" id="trigger_right_params_box">
                                <property name="orientation">vertical</property>
                                <property name="spacing">4</property>
                              </object>
                            </child>
                          </object>
                          <packing><property name="expand">True</property><property name="fill">True</property></packing>
                        </child>

                        <child>
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <property name="spacing">8</property>
                            <property name="homogeneous">True</property>
                            <child>
                              <object class="GtkButton" id="trigger_right_apply">
                                <property name="label" translatable="yes">Aplicar em R2</property>
                                <signal name="clicked" handler="on_trigger_right_apply"/>
                              <child internal-child="accessible">
                                <object class="AtkObject">
                                  <property name="AtkObject::accessible-name" translatable="yes">Aplicar gatilho adaptativo no R2</property>
                                  <property name="AtkObject::accessible-description" translatable="yes">Envia configuracao do gatilho direito ao controle</property>
                                </object>
                              </child>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="trigger_right_reset">
                                <property name="label" translatable="yes">Desligar</property>
                                <signal name="clicked" handler="on_trigger_right_reset"/>
                              <child internal-child="accessible">
                                <object class="AtkObject">
                                  <property name="AtkObject::accessible-name" translatable="yes">Desligar gatilho R2</property>
                                  <property name="AtkObject::accessible-description" translatable="yes">Restaura R2 ao modo Off (sem resistencia)</property>
                                </object>
                              </child>
                              </object>
                            </child>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>
                      </object>
                    </child>
                  </object>
                  <packing><property name="expand">True</property><property name="fill">True</property></packing>
                </child>

              </object>
            </child>
            <child type="tab">
              <object class="GtkLabel"><property name="label" translatable="yes">Gatilhos</property></object>
            </child>

            <!-- ABA LIGHTBAR + PLAYER LEDS -->
            <child>
              <object class="GtkBox" id="tab_lightbar_box">
                <property name="orientation">horizontal</property>
                <property name="spacing">12</property>
                <property name="margin">12</property>

                <child>
                  <object class="GtkFrame">
                    <property name="label" translatable="yes">Lightbar (barra de LED)</property>
                    <property name="hexpand">True</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">12</property>
                        <property name="margin">16</property>

                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">Escolha a cor da barra de LED do DualSense.</property>
                            <property name="xalign">0</property>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>

                        <!-- COR-04: cores automáticas por controle (toggle do perfil).
                             Sem <signal> de propósito: a fiação é em código
                             (install_lightbar_tab), fora do dict de app.py. -->
                        <child>
                          <object class="GtkBox">
                            <property name="orientation">vertical</property>
                            <property name="spacing">2</property>
                            <child>
                              <object class="GtkCheckButton" id="auto_player_colors_check">
                                <property name="label" translatable="yes">Cores automáticas por controle</property>
                              <child internal-child="accessible">
                                <object class="AtkObject">
                                  <property name="AtkObject::accessible-name" translatable="yes">Cores automáticas por controle</property>
                                  <property name="AtkObject::accessible-description" translatable="yes">Cada DualSense conectado ganha uma cor de jogador automaticamente</property>
                                </object>
                              </child>
                              </object>
                              <packing><property name="expand">False</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel" id="auto_player_colors_subtitle">
                                <property name="label" translatable="yes">&lt;i&gt;Cada DualSense ganha uma cor de jogador, estilo PS5.&lt;/i&gt;</property>
                                <property name="use-markup">True</property>
                                <property name="xalign">0</property>
                                <property name="wrap">True</property>
                                <property name="margin-start">24</property>
                              </object>
                              <packing><property name="expand">False</property></packing>
                            </child>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>

                        <child>
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <property name="spacing">16</property>

                            <child>
                              <object class="GtkColorButton" id="lightbar_color_button">
                                <property name="title" translatable="yes">Selecione a cor</property>
                                <property name="use-alpha">False</property>
                                <signal name="color-set" handler="on_lightbar_color_set"/>
                              </object>
                              <packing><property name="expand">False</property></packing>
                            </child>

                            <child>
                              <object class="GtkFrame">
                                <property name="label" translatable="yes">Prévia</property>
                                <property name="hexpand">True</property>
                                <child>
                                  <object class="GtkDrawingArea" id="lightbar_preview">
                                    <property name="width-request">180</property>
                                    <property name="height-request">60</property>
                                  </object>
                                </child>
                              </object>
                              <packing><property name="expand">True</property></packing>
                            </child>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>

                        <child>
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <property name="spacing">8</property>
                            <property name="homogeneous">True</property>
                            <child>
                              <object class="GtkButton" id="lightbar_apply">
                                <property name="label" translatable="yes">Aplicar no controle</property>
                                <signal name="clicked" handler="on_lightbar_apply"/>
                              <child internal-child="accessible">
                                <object class="AtkObject">
                                  <property name="AtkObject::accessible-name" translatable="yes">Aplicar cor na lightbar</property>
                                  <property name="AtkObject::accessible-description" translatable="yes">Envia cor selecionada para a barra de LED do controle</property>
                                </object>
                              </child>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="lightbar_off">
                                <property name="label" translatable="yes">Apagar</property>
                                <signal name="clicked" handler="on_lightbar_off"/>
                              <child internal-child="accessible">
                                <object class="AtkObject">
                                  <property name="AtkObject::accessible-name" translatable="yes">Apagar lightbar</property>
                                  <property name="AtkObject::accessible-description" translatable="yes">Desliga a barra de LED do controle</property>
                                </object>
                              </child>
                              </object>
                            </child>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>

                        <!-- COR-04: desfazer cor explícita (por alvo e em lote).
                             Sem <signal>: fiação em código (install_lightbar_tab). -->
                        <child>
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <property name="spacing">8</property>
                            <property name="homogeneous">True</property>
                            <child>
                              <object class="GtkButton" id="lightbar_auto_reset_target">
                                <property name="label" translatable="yes">Voltar ao automático</property>
                                <property name="tooltip-text" translatable="yes">Remove a cor escolhida do controle selecionado no seletor acima — a cor automática volta a valer nele.</property>
                              <child internal-child="accessible">
                                <object class="AtkObject">
                                  <property name="AtkObject::accessible-name" translatable="yes">Voltar o controle selecionado ao automático</property>
                                  <property name="AtkObject::accessible-description" translatable="yes">Remove a cor escolhida do controle selecionado; a cor automática volta a valer nele</property>
                                </object>
                              </child>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="lightbar_auto_reset_all">
                                <property name="label" translatable="yes">Voltar todos ao automático</property>
                                <property name="tooltip-text" translatable="yes">Remove as cores escolhidas de todos os controles e religa as cores automáticas.</property>
                              <child internal-child="accessible">
                                <object class="AtkObject">
                                  <property name="AtkObject::accessible-name" translatable="yes">Voltar todos os controles ao automático</property>
                                  <property name="AtkObject::accessible-description" translatable="yes">Remove as cores escolhidas de todos os controles e religa as cores automáticas</property>
                                </object>
                              </child>
                              </object>
                            </child>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>

                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">Luminosidade (%)</property>
                            <property name="xalign">0</property>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>

                        <child>
                          <object class="GtkScale" id="lightbar_brightness_scale">
                            <property name="draw-value">True</property>
                            <property name="digits">0</property>
                            <property name="value-pos">right</property>
                            <property name="hexpand">True</property>
                            <property name="adjustment">lightbar_brightness_adj</property>
                            <signal name="value-changed" handler="on_lightbar_brightness_changed"/>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>
                      </object>
                    </child>
                  </object>
                  <packing><property name="expand">True</property><property name="fill">True</property></packing>
                </child>

                <child>
                  <object class="GtkFrame">
                    <property name="label" translatable="yes">LEDs de Jogador</property>
                    <property name="hexpand">True</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">8</property>
                        <property name="margin">16</property>

                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">Escolha o jogador — o desenho dos 5 LEDs é o padrão oficial do PS5.</property>
                            <property name="xalign">0</property>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>

                        <child>
                          <!-- LEDS-SO-PLAYER-01 (22/07, pedido da mantenedora): a seleção
                               LED a LED confundia — "player 1 acende o LED 3" parecia bug,
                               mas é o padrão oficial do PS5. Os checkboxes ficam OCULTOS
                               (no-show-all) e seguem sendo o estado interno que os presets
                               de player escrevem e o "Aplicar LEDs" lê — só a superfície
                               de UI mudou; nenhum handler/fluxo foi alterado. -->
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <property name="spacing">8</property>
                            <property name="homogeneous">True</property>
                            <property name="visible">False</property>
                            <property name="no-show-all">True</property>
                            <child><object class="GtkCheckButton" id="player_led_1"><property name="label" translatable="yes">LED 1</property><signal name="toggled" handler="on_player_led_toggled"/></object></child>
                            <child><object class="GtkCheckButton" id="player_led_2"><property name="label" translatable="yes">LED 2</property><signal name="toggled" handler="on_player_led_toggled"/></object></child>
                            <child><object class="GtkCheckButton" id="player_led_3"><property name="label" translatable="yes">LED 3</property><signal name="toggled" handler="on_player_led_toggled"/></object></child>
                            <child><object class="GtkCheckButton" id="player_led_4"><property name="label" translatable="yes">LED 4</property><signal name="toggled" handler="on_player_led_toggled"/></object></child>
                            <child><object class="GtkCheckButton" id="player_led_5"><property name="label" translatable="yes">LED 5</property><signal name="toggled" handler="on_player_led_toggled"/></object></child>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>

                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">&lt;b&gt;Presets rápidos:&lt;/b&gt;</property>
                            <property name="use-markup">True</property>
                            <property name="xalign">0</property>
                            <property name="margin-top">8</property>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>

                        <child>
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <property name="spacing">6</property>
                            <property name="homogeneous">True</property>
                            <child>
                              <object class="GtkButton" id="player_leds_preset_all">
                                <property name="label" translatable="yes">Todos</property>
                                <signal name="clicked" handler="on_player_leds_preset_all"/>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="player_leds_preset_p1">
                                <property name="label" translatable="yes">Player 1</property>
                                <property name="tooltip_text" translatable="yes">Padrão oficial do PS5: o Player 1 acende só o LED central (igual ao console)</property>
                                <signal name="clicked" handler="on_player_leds_preset_p1"/>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="player_leds_preset_p2">
                                <property name="label" translatable="yes">Player 2</property>
                                <property name="tooltip_text" translatable="yes">Padrão oficial do PS5: o Player 2 acende os 2 LEDs vizinhos do centro (igual ao console)</property>
                                <signal name="clicked" handler="on_player_leds_preset_p2"/>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="player_leds_preset_p3">
                                <property name="label" translatable="yes">Player 3</property>
                                <property name="tooltip_text" translatable="yes">Padrão oficial do PS5: o Player 3 acende 3 LEDs alternados (igual ao console)</property>
                                <signal name="clicked" handler="on_player_leds_preset_p3"/>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="player_leds_preset_p4">
                                <property name="label" translatable="yes">Player 4</property>
                                <property name="tooltip_text" translatable="yes">Padrão oficial do PS5: o Player 4 acende os 4 LEDs externos (igual ao console)</property>
                                <signal name="clicked" handler="on_player_leds_preset_p4"/>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="player_leds_preset_none">
                                <property name="label" translatable="yes">Nenhum</property>
                                <signal name="clicked" handler="on_player_leds_preset_none"/>
                              </object>
                            </child>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>

                        <child>
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <property name="spacing">6</property>
                            <property name="margin-top">8</property>
                            <child>
                              <object class="GtkButton" id="player_leds_apply">
                                <property name="label" translatable="yes">Aplicar LEDs</property>
                                <property name="tooltip-text" translatable="yes">Reenvia o padrão atual dos 5 checkboxes ao controle via daemon.</property>
                                <signal name="clicked" handler="on_player_leds_apply"/>
                              <child internal-child="accessible">
                                <object class="AtkObject">
                                  <property name="AtkObject::accessible-name" translatable="yes">Aplicar LEDs de jogador</property>
                                  <property name="AtkObject::accessible-description" translatable="yes">Reenvia o padrao atual dos 5 LEDs ao controle</property>
                                </object>
                              </child>
                              </object>
                              <packing><property name="expand">False</property></packing>
                            </child>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>

                        <child>
                          <object class="GtkLabel" id="player_leds_note">
                            <property name="label" translatable="yes">&lt;i&gt;Checkboxes e presets enviam imediatamente ao hardware. Use &quot;Aplicar LEDs&quot; para reenviar o padrão atual (útil após reconectar o controle ou trocar de perfil). As marcações ficam salvas no perfil ativo.&lt;/i&gt;</property>
                            <property name="use-markup">True</property>
                            <property name="xalign">0</property>
                            <property name="wrap">True</property>
                            <property name="margin-top">8</property>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>

                        <!-- COR-04: com o automático ligado, o LED do número
                             do controle vence os interruptores manuais. -->
                        <child>
                          <object class="GtkLabel" id="player_leds_auto_note">
                            <property name="label" translatable="yes">&lt;i&gt;Os interruptores manuais valem com as cores automáticas desligadas.&lt;/i&gt;</property>
                            <property name="use-markup">True</property>
                            <property name="xalign">0</property>
                            <property name="wrap">True</property>
                            <property name="margin-top">4</property>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>
                      </object>
                    </child>
                  </object>
                  <packing><property name="expand">True</property><property name="fill">True</property></packing>
                </child>
              </object>
            </child>
            <child type="tab">
              <object class="GtkLabel"><property name="label" translatable="yes">Lightbar</property></object>
            </child>

            <!-- ABA RUMBLE — FEAT-RUMBLE-POLICY-01 -->
            <child>
              <object class="GtkBox" id="tab_rumble_box">
                <property name="orientation">vertical</property>
                <property name="spacing">12</property>
                <property name="margin">16</property>

                <!-- Card 1: Intensidade da vibração -->
                <child>
                  <object class="GtkFrame">
                    <property name="label" translatable="yes">Intensidade da vibração</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">10</property>
                        <property name="margin">14</property>

                        <!-- Linha de toggles de política -->
                        <child>
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <property name="spacing">6</property>
                            <property name="homogeneous">True</property>

                            <child>
                              <object class="GtkToggleButton" id="rumble_policy_economia">
                                <property name="label" translatable="yes">Economia</property>
                                <property name="active">False</property>
                                <signal name="toggled" handler="on_rumble_policy_economia"/>
                              </object>
                            </child>
                            <child>
                              <object class="GtkToggleButton" id="rumble_policy_balanceado">
                                <property name="label" translatable="yes">Balanceado</property>
                                <property name="active">True</property>
                                <signal name="toggled" handler="on_rumble_policy_balanceado"/>
                              </object>
                            </child>
                            <child>
                              <object class="GtkToggleButton" id="rumble_policy_max">
                                <property name="label" translatable="yes">Máximo</property>
                                <property name="active">False</property>
                                <signal name="toggled" handler="on_rumble_policy_max"/>
                              </object>
                            </child>
                            <child>
                              <object class="GtkToggleButton" id="rumble_policy_auto">
                                <property name="label" translatable="yes">Auto</property>
                                <property name="active">False</property>
                                <signal name="toggled" handler="on_rumble_policy_auto"/>
                              </object>
                            </child>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>

                        <!-- Slider de intensidade global -->
                        <child>
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <property name="spacing">8</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="label" translatable="yes">Intensidade global:</property>
                                <property name="xalign">0</property>
                              </object>
                              <packing><property name="expand">False</property></packing>
                            </child>
                            <child>
                              <object class="GtkScale" id="rumble_policy_slider">
                                <property name="hexpand">True</property>
                                <property name="draw-value">True</property>
                                <property name="digits">0</property>
                                <property name="value-pos">right</property>
                                <property name="adjustment">rumble_policy_adj</property>
                                <signal name="value-changed" handler="on_rumble_policy_slider_changed"/>
                              </object>
                              <packing><property name="expand">True</property><property name="fill">True</property></packing>
                            </child>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>

                        <!-- Label educativo do modo Auto (oculto por padrão) -->
                        <child>
                          <object class="GtkLabel" id="rumble_policy_auto_label">
                            <property name="label" translatable="yes">Modo Auto: ajusta intensidade conforme a bateria do controle.
Bateria &gt;50%: 100% (Máximo).  20-50%: 70% (Balanceado).  &lt;20%: 30% (Economia).
Transições com debounce de 5 segundos para evitar oscilação.</property>
                            <property name="xalign">0</property>
                            <property name="wrap">True</property>
                            <property name="visible">False</property>
                            <property name="no-show-all">True</property>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>

                      </object>
                    </child>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>

                <!-- Card 2: Testar motores -->
                <child>
                  <object class="GtkFrame">
                    <property name="label" translatable="yes">Testar motores</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">10</property>
                        <property name="margin">14</property>

                        <child>
                          <object class="GtkGrid">
                            <property name="row-spacing">10</property>
                            <property name="column-spacing">12</property>

                            <child>
                              <object class="GtkLabel">
                                <property name="label" translatable="yes">Vibração leve</property>
                                <property name="xalign">0</property>
                              </object>
                              <packing><property name="left-attach">0</property><property name="top-attach">0</property></packing>
                            </child>
                            <child>
                              <object class="GtkScale" id="rumble_weak_scale">
                                <property name="draw-value">True</property>
                                <property name="digits">0</property>
                                <property name="value-pos">right</property>
                                <property name="hexpand">True</property>
                                <property name="adjustment">rumble_weak_adj</property>
                              </object>
                              <packing><property name="left-attach">1</property><property name="top-attach">0</property></packing>
                            </child>

                            <child>
                              <object class="GtkLabel">
                                <property name="label" translatable="yes">Vibração forte</property>
                                <property name="xalign">0</property>
                              </object>
                              <packing><property name="left-attach">0</property><property name="top-attach">1</property></packing>
                            </child>
                            <child>
                              <object class="GtkScale" id="rumble_strong_scale">
                                <property name="draw-value">True</property>
                                <property name="digits">0</property>
                                <property name="value-pos">right</property>
                                <property name="hexpand">True</property>
                                <property name="adjustment">rumble_strong_adj</property>
                              </object>
                              <packing><property name="left-attach">1</property><property name="top-attach">1</property></packing>
                            </child>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>

                        <child>
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <property name="spacing">8</property>
                            <property name="homogeneous">True</property>
                            <child>
                              <object class="GtkButton" id="rumble_test_500ms">
                                <property name="label" translatable="yes">Testar por 500 ms</property>
                                <signal name="clicked" handler="on_rumble_test_500ms"/>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="rumble_apply">
                                <property name="label" translatable="yes">Aplicar</property>
                                <signal name="clicked" handler="on_rumble_apply"/>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="rumble_stop">
                                <property name="label" translatable="yes">Parar</property>
                                <property name="tooltip-text" translatable="yes">Trava o controle em silêncio: nada vibra, nem no jogo. Para o jogo voltar a comandar, clique em 'Deixar o jogo controlar a vibração'.</property>
                                <signal name="clicked" handler="on_rumble_stop"/>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="rumble_passthrough">
                                <property name="label" translatable="yes">Deixar o jogo controlar a vibração</property>
                                <property name="tooltip-text" translatable="yes">Devolve a vibração ao jogo. Use depois de 'Parar' para o jogo voltar a fazer o controle vibrar.</property>
                                <signal name="clicked" handler="on_rumble_passthrough"/>
                              </object>
                            </child>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>

                        <child>
                          <object class="GtkLabel" id="rumble_state_label">
                            <property name="label" translatable="yes">Estado da vibração: —</property>
                            <property name="use-markup">True</property>
                            <property name="xalign">0</property>
                            <property name="wrap">True</property>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>

                        <child>
                          <object class="GtkLabel" id="rumble_info">
                            <property name="label" translatable="yes">&lt;i&gt;Os valores acima ainda passam pela intensidade escolhida ali em cima antes de chegar ao controle.&lt;/i&gt;</property>
                            <property name="use-markup">True</property>
                            <property name="xalign">0</property>
                            <property name="wrap">True</property>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>

                      </object>
                    </child>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>

              </object>
            </child>
            <child type="tab">
              <object class="GtkLabel"><property name="label" translatable="yes">Rumble</property></object>
            </child>

            <!-- Aba Perfis -->
            <child>
              <object class="GtkBox" id="profiles_paned">
                <property name="orientation">horizontal</property>
                <property name="margin">10</property>
                <property name="spacing">16</property>
                <child>
                  <!-- Painel esquerdo: lista de perfis + botões de ação -->
                  <object class="GtkBox" id="profiles_left_box">
                    <property name="width-request">360</property>
                    <property name="orientation">vertical</property>
                    <property name="spacing">8</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">&lt;b&gt;Perfis salvos&lt;/b&gt;</property>
                        <property name="use-markup">True</property>
                        <property name="xalign">0</property>
                      </object>
                      <packing><property name="expand">False</property></packing>
                    </child>
                    <child>
                      <object class="GtkScrolledWindow">
                        <property name="hscrollbar-policy">never</property>
                        <property name="vscrollbar-policy">automatic</property>
                        <property name="hexpand">True</property>
                        <property name="vexpand">True</property>
                        <child>
                          <!-- ONDA-U (U3-B): "row-activated" (duplo-clique)
                               foi REMOVIDO — atropelava edição em andamento
                               (duplo-clique acidental ativava o perfil na
                               hora, sem confirmação, via profile.switch). O
                               botão "Ativar" já cobre o gesto explícito de
                               trocar de perfil; menos intrusivo que somar
                               uma confirmação a um segundo caminho. -->
                          <object class="GtkTreeView" id="profiles_tree">
                            <property name="headers-visible">True</property>
                          </object>
                        </child>
                      </object>
                      <packing><property name="expand">True</property><property name="fill">True</property></packing>
                    </child>
                    <child>
                      <object class="GtkBox" id="profiles_btnbox">
                        <property name="orientation">horizontal</property>
                        <property name="spacing">4</property>
                        <property name="homogeneous">True</property>
                        <child>
                          <object class="GtkButton" id="profile_new_button">
                            <property name="label" translatable="yes">Novo</property>
                            <signal name="clicked" handler="on_profile_new"/>
                          <child internal-child="accessible">
                            <object class="AtkObject">
                              <property name="AtkObject::accessible-name" translatable="yes">Criar novo perfil</property>
                              <property name="AtkObject::accessible-description" translatable="yes">Abre dialogo para criar um perfil em branco</property>
                            </object>
                          </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="profile_duplicate_button">
                            <property name="label" translatable="yes">Duplicar</property>
                            <signal name="clicked" handler="on_profile_duplicate"/>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="profile_remove_button">
                            <property name="label" translatable="yes">Remover</property>
                            <signal name="clicked" handler="on_profile_remove"/>
                          <child internal-child="accessible">
                            <object class="AtkObject">
                              <property name="AtkObject::accessible-name" translatable="yes">Remover perfil selecionado</property>
                              <property name="AtkObject::accessible-description" translatable="yes">Apaga permanentemente o perfil destacado na lista</property>
                            </object>
                          </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="profile_activate_button">
                            <property name="label" translatable="yes">Ativar</property>
                            <signal name="clicked" handler="on_profile_activate"/>
                          <child internal-child="accessible">
                            <object class="AtkObject">
                              <property name="AtkObject::accessible-name" translatable="yes">Ativar perfil selecionado</property>
                              <property name="AtkObject::accessible-description" translatable="yes">Aplica o perfil destacado e o marca como ativo</property>
                            </object>
                          </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="profile_reload_button">
                            <property name="label" translatable="yes">Recarregar</property>
                            <signal name="clicked" handler="on_profile_reload"/>
                          </object>
                        </child>
                      </object>
                      <packing><property name="expand">False</property></packing>
                    </child>
                  </object>
                  <packing><property name="expand">False</property><property name="fill">True</property></packing>
                </child>

                <!-- Painel direito: editor do perfil com toggle Modo avançado -->
                <child>
                  <object class="GtkBox" id="profiles_right_box">
                    <property name="orientation">vertical</property>
                    <property name="spacing">8</property>

                    <!-- Cabeçalho: título + toggle Modo avançado -->
                    <child>
                      <object class="GtkBox" id="profiles_editor_header">
                        <property name="orientation">horizontal</property>
                        <property name="spacing">8</property>
                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">&lt;b&gt;Editor do perfil&lt;/b&gt;</property>
                            <property name="use-markup">True</property>
                            <property name="xalign">0</property>
                          </object>
                          <packing><property name="expand">True</property><property name="fill">True</property></packing>
                        </child>
                        <child>
                          <object class="GtkLabel" id="profile_advanced_toggle_label">
                            <property name="label" translatable="yes">Modo avançado</property>
                            <property name="xalign">1</property>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>
                        <child>
                          <object class="GtkSwitch" id="profile_advanced_switch">
                            <property name="halign">end</property>
                            <property name="valign">center</property>
                            <property name="active">False</property>
                            <property name="tooltip-text" translatable="yes">Ativa campos técnicos (window_class, title_regex, process_name)</property>
                            <signal name="state-set" handler="on_profile_advanced_toggle"/>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>
                      </object>
                      <packing><property name="expand">False</property></packing>
                    </child>

                    <!-- Campos comuns: Nome + Prioridade (sempre visíveis) -->
                    <child>
                      <object class="GtkGrid" id="profiles_common_grid">
                        <property name="row-spacing">6</property>
                        <property name="column-spacing">10</property>
                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">Nome:</property>
                            <property name="xalign">1</property>
                          </object>
                          <packing><property name="left-attach">0</property><property name="top-attach">0</property></packing>
                        </child>
                        <child>
                          <object class="GtkEntry" id="profile_name_entry">
                            <property name="hexpand">True</property>
                          </object>
                          <packing><property name="left-attach">1</property><property name="top-attach">0</property></packing>
                        </child>
                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">Prioridade:</property>
                            <property name="xalign">1</property>
                          </object>
                          <packing><property name="left-attach">0</property><property name="top-attach">1</property></packing>
                        </child>
                        <child>
                          <!-- GtkScale substitui SpinButton — range 0-100, step 5.
                               H6 (UI-PROFILES-LAYOUT-POLISH-01): marks 0/50/100 no
                               bottom dão referência visual dos extremos. -->
                          <object class="GtkScale" id="profile_priority_scale">
                            <property name="adjustment">profile_priority_adj</property>
                            <property name="draw-value">True</property>
                            <property name="digits">0</property>
                            <property name="value-pos">right</property>
                            <property name="hexpand">True</property>
                            <property name="tooltip-text" translatable="yes">Quanto maior, mais prioritário que outros perfis (0-100)</property>
                            <marks>
                              <mark value="0" position="bottom">0</mark>
                              <mark value="50" position="bottom">50</mark>
                              <mark value="100" position="bottom">100</mark>
                            </marks>
                          </object>
                          <packing><property name="left-attach">1</property><property name="top-attach">1</property></packing>
                        </child>
                      </object>
                      <packing><property name="expand">False</property></packing>
                    </child>

                    <!-- GtkStack: alterna entre modo simples e avançado -->
                    <child>
                      <object class="GtkStack" id="profile_editor_stack">
                        <property name="transition-type">slide-left-right</property>
                        <property name="transition-duration">200</property>

                        <!-- Página simples -->
                        <child>
                          <object class="GtkBox" id="profile_stack_simples">
                            <property name="orientation">vertical</property>
                            <property name="spacing">10</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="label" translatable="yes">&lt;b&gt;Aplica a:&lt;/b&gt;</property>
                                <property name="use-markup">True</property>
                                <property name="xalign">0</property>
                              </object>
                              <packing><property name="expand">False</property></packing>
                            </child>

                            <!-- "Aplica a:" — UI-PROFILES-RADIO-GROUP-REDESIGN-01 +
                                 FEAT-DSX-COMBO-TO-SEGMENTED-01: slot do SegmentedSelector
                                 (botões segmentados, sem popup; imune ao bug do cosmic-comp,
                                 que fechava o popup do combo no clique). Os itens (id, label)
                                 são ligados no código (profiles_actions.install_profiles_tab). -->
                            <child>
                              <object class="GtkBox" id="profile_aplica_a_slot">
                                <property name="orientation">horizontal</property>
                                <property name="hexpand">True</property>
                              </object>
                              <packing><property name="expand">False</property></packing>
                            </child>

                            <!-- Entry "Jogo específico" — visível só quando combo == "game" -->
                            <child>
                              <object class="GtkBox" id="profile_game_entry_box">
                                <property name="orientation">horizontal</property>
                                <property name="spacing">6</property>
                                <property name="visible">False</property>
                                <property name="no-show-all">True</property>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="label" translatable="yes">Nome do jogo:</property>
                                    <property name="xalign">1</property>
                                  </object>
                                  <packing><property name="expand">False</property></packing>
                                </child>
                                <child>
                                  <object class="GtkEntry" id="profile_simple_custom_name">
                                    <property name="hexpand">True</property>
                                    <property name="placeholder-text" translatable="yes">ex.: eldenring</property>
                                    <property name="tooltip-text" translatable="yes">Nome do executável do jogo (sem extensão no Linux)</property>
                                  </object>
                                  <packing><property name="expand">True</property><property name="fill">True</property></packing>
                                </child>
                              </object>
                              <packing><property name="expand">False</property></packing>
                            </child>

                          </object>
                          <packing>
                            <property name="name">simples</property>
                            <property name="title" translatable="yes">Simples</property>
                          </packing>
                        </child>

                        <!-- Página avançada -->
                        <child>
                          <object class="GtkBox" id="profile_stack_avancado">
                            <property name="orientation">vertical</property>
                            <property name="spacing">6</property>
                            <child>
                              <object class="GtkGrid" id="profiles_advanced_grid">
                                <property name="row-spacing">6</property>
                                <property name="column-spacing">10</property>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="label" translatable="yes">window_class:</property>
                                    <property name="xalign">1</property>
                                  </object>
                                  <packing><property name="left-attach">0</property><property name="top-attach">0</property></packing>
                                </child>
                                <child>
                                  <object class="GtkEntry" id="profile_window_class_entry">
                                    <property name="placeholder-text" translatable="yes">CSV: Steam,firefox</property>
                                    <property name="hexpand">True</property>
                                  </object>
                                  <packing><property name="left-attach">1</property><property name="top-attach">0</property></packing>
                                </child>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="label" translatable="yes">title_regex:</property>
                                    <property name="xalign">1</property>
                                  </object>
                                  <packing><property name="left-attach">0</property><property name="top-attach">1</property></packing>
                                </child>
                                <child>
                                  <object class="GtkEntry" id="profile_title_regex_entry">
                                    <property name="placeholder-text" translatable="yes">regex (re.search)</property>
                                    <property name="hexpand">True</property>
                                  </object>
                                  <packing><property name="left-attach">1</property><property name="top-attach">1</property></packing>
                                </child>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="label" translatable="yes">process_name:</property>
                                    <property name="xalign">1</property>
                                  </object>
                                  <packing><property name="left-attach">0</property><property name="top-attach">2</property></packing>
                                </child>
                                <child>
                                  <object class="GtkEntry" id="profile_process_name_entry">
                                    <property name="placeholder-text" translatable="yes">CSV: doom.x86_64,celeste</property>
                                    <property name="hexpand">True</property>
                                  </object>
                                  <packing><property name="left-attach">1</property><property name="top-attach">2</property></packing>
                                </child>
                              </object>
                              <packing><property name="expand">False</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel" id="profile_editor_hint">
                                <property name="label" translatable="yes">&lt;i&gt;AND entre campos preenchidos, OR dentro de cada lista. Campos vazios são ignorados.&lt;/i&gt;</property>
                                <property name="use-markup">True</property>
                                <property name="xalign">0</property>
                                <property name="wrap">True</property>
                              </object>
                              <packing><property name="expand">False</property></packing>
                            </child>
                          </object>
                          <packing>
                            <property name="name">avancado</property>
                            <property name="title" translatable="yes">Avancado</property>
                          </packing>
                        </child>

                      </object>
                      <packing><property name="expand">False</property><property name="fill">True</property></packing>
                    </child>

                    <!-- Modo do sistema por perfil — FEAT-PROFILE-MODE-GUI-01:
                         slot para os widgets dinâmicos montados no código
                         (profiles_actions._install_mode_section). SegmentedSelector
                         + co-op + máscara; nunca GtkComboBox (o cosmic-comp fecha
                         o popup do combo no clique). Fica FORA da stack simples/
                         avançado porque o modo pertence ao perfil, não ao match. -->
                    <child>
                      <object class="GtkFrame" id="profile_mode_frame">
                        <property name="label" translatable="yes">Modo (o que este perfil liga ao ativar)</property>
                        <property name="margin-top">8</property>
                        <child>
                          <object class="GtkBox" id="profile_mode_slot">
                            <property name="orientation">vertical</property>
                            <property name="spacing">6</property>
                            <property name="margin">8</property>
                          </object>
                        </child>
                      </object>
                      <packing><property name="expand">False</property></packing>
                    </child>

                    <!-- Preview JSON — UI-PROFILES-RIGHT-PANEL-REBALANCE-01
                         Mostra o Profile que seria salvo, em tempo real.
                         Reutiliza o `_build_profile_from_editor` como fonte de
                         verdade. Ocupa o espaço vazio criado após o combo da
                         sprint 77 (~450px antes, ~280px agora com preview). -->
                    <child>
                      <object class="GtkFrame">
                        <property name="label" translatable="yes">Detalhes técnicos</property>
                        <property name="margin-top">8</property>
                        <child>
                          <object class="GtkScrolledWindow">
                            <property name="hscrollbar-policy">automatic</property>
                            <property name="vscrollbar-policy">automatic</property>
                            <property name="min-content-height">180</property>
                            <property name="propagate-natural-height">True</property>
                            <child>
                              <object class="GtkLabel" id="profile_preview_label">
                                <property name="label" translatable="yes">(selecione um perfil para ver o preview)</property>
                                <property name="xalign">0</property>
                                <property name="yalign">0</property>
                                <property name="wrap">True</property>
                                <property name="selectable">True</property>
                                <property name="margin">8</property>
                                <style>
                                  <class name="hefesto-profile-preview"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                      <packing><property name="expand">True</property><property name="fill">True</property></packing>
                    </child>

                    <!-- Rodapé: botão Salvar -->
                    <child>
                      <object class="GtkButtonBox">
                        <property name="orientation">horizontal</property>
                        <property name="layout-style">end</property>
                        <property name="spacing">6</property>
                        <child>
                          <object class="GtkButton" id="profile_save_button">
                            <property name="label" translatable="yes">Salvar</property>
                            <signal name="clicked" handler="on_profile_save"/>
                          </object>
                        </child>
                      </object>
                      <packing><property name="expand">False</property></packing>
                    </child>

                  </object>
                  <packing><property name="expand">True</property><property name="fill">True</property></packing>
                </child>
              </object>
            </child>
            <child type="tab">
              <object class="GtkLabel"><property name="label" translatable="yes">Perfis</property></object>
            </child>

            <!-- Aba Sistema (LEIGO-03: era "Daemon"; o systemd não é assunto
                 de quem usa — a linha "Unit: hefesto-dualsense4unix.service"
                 saiu daqui e o id do serviço vive só no código/log) -->
            <child>
              <object class="GtkBox" id="daemon_box">
                <property name="orientation">vertical</property>
                <property name="margin">12</property>
                <property name="spacing">10</property>
                <child>
                  <object class="GtkGrid" id="daemon_status_grid">
                    <property name="row-spacing">6</property>
                    <property name="column-spacing">10</property>
                    <child>
                      <object class="GtkLabel"><property name="label" translatable="yes">O Hefesto está:</property><property name="xalign">1</property></object>
                      <packing><property name="left-attach">0</property><property name="top-attach">1</property></packing>
                    </child>
                    <child>
                      <object class="GtkLabel" id="daemon_status_label">
                        <property name="label">—</property>
                        <property name="xalign">0</property>
                        <property name="use-markup">True</property>
                      </object>
                      <packing><property name="left-attach">1</property><property name="top-attach">1</property></packing>
                    </child>
                    <child>
                      <object class="GtkLabel"><property name="label" translatable="yes">Ligar junto com o computador:</property><property name="xalign">1</property></object>
                      <packing><property name="left-attach">0</property><property name="top-attach">2</property></packing>
                    </child>
                    <child>
                      <object class="GtkSwitch" id="daemon_autostart_switch">
                        <property name="halign">start</property>
                        <signal name="state-set" handler="on_daemon_autostart_toggled"/>
                      </object>
                      <packing><property name="left-attach">1</property><property name="top-attach">2</property></packing>
                    </child>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>
                <child>
                  <object class="GtkBox" id="daemon_btns">
                    <property name="orientation">horizontal</property>
                    <property name="spacing">4</property>
                    <property name="homogeneous">True</property>
                    <child>
                      <object class="GtkButton" id="daemon_start_button">
                        <property name="label" translatable="yes">Ligar o Hefesto</property>
                        <signal name="clicked" handler="on_daemon_start"/>
                      <child internal-child="accessible">
                        <object class="AtkObject">
                          <property name="AtkObject::accessible-name" translatable="yes">Ligar o Hefesto</property>
                          <property name="AtkObject::accessible-description" translatable="yes">Liga o Hefesto: luzes, gatilhos e seus ajustes voltam a valer</property>
                        </object>
                      </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="daemon_stop_button">
                        <property name="label" translatable="yes">Desligar o Hefesto</property>
                        <signal name="clicked" handler="on_daemon_stop"/>
                      <child internal-child="accessible">
                        <object class="AtkObject">
                          <property name="AtkObject::accessible-name" translatable="yes">Desligar o Hefesto</property>
                          <property name="AtkObject::accessible-description" translatable="yes">Desliga o Hefesto: o controle continua funcionando, mas sem luzes, gatilhos nem seus ajustes</property>
                        </object>
                      </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="daemon_refresh_button">
                        <property name="label" translatable="yes">Atualizar</property>
                        <signal name="clicked" handler="on_daemon_refresh"/>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="daemon_logs_button">
                        <property name="label" translatable="yes">Ver detalhes</property>
                        <property name="tooltip-text" translatable="yes">Mostra o registro técnico do Hefesto aqui embaixo — útil para relatar um problema.</property>
                        <signal name="clicked" handler="on_daemon_view_logs"/>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="btn_restart_daemon">
                        <property name="label" translatable="yes">Reiniciar o Hefesto</property>
                        <property name="tooltip-text" translatable="yes">Desliga e liga o Hefesto de novo — resolve a maioria dos travamentos.</property>
                        <signal name="clicked" handler="on_daemon_service_restart"/>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="btn_migrate_to_systemd">
                        <property name="label" translatable="yes">Corrigir modo de execução</property>
                        <property name="tooltip-text" translatable="yes">O Hefesto está rodando de um jeito improvisado: não liga sozinho nem se recupera se travar. Este botão o coloca no jeito certo.</property>
                        <property name="visible">False</property>
                        <property name="no-show-all">True</property>
                        <signal name="clicked" handler="on_daemon_migrate_to_systemd"/>
                      </object>
                    </child>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>
                <!-- FEAT-DSX-UNIFY-01: cartão anti-storm / sistema -->
                <child>
                  <object class="GtkBox" id="storm_card">
                    <property name="orientation">vertical</property>
                    <property name="spacing">4</property>
                    <style><class name="hefesto-dualsense4unix-card"/></style>
                    <child>
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">&lt;b&gt;Saúde do sistema&lt;/b&gt;</property>
                        <property name="use-markup">True</property>
                        <property name="xalign">0</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="storm_diag_label">
                        <property name="label" translatable="yes">Diagnóstico ao abrir a aba…</property>
                        <property name="use-markup">True</property>
                        <property name="xalign">0</property>
                        <property name="selectable">True</property>
                        <property name="wrap">True</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">horizontal</property>
                        <property name="spacing">4</property>
                        <child>
                          <object class="GtkButton" id="btn_storm_fix_safe">
                            <property name="label" translatable="yes">Aplicar correções</property>
                            <property name="tooltip-text" translatable="yes">Não pede senha: desliga o Steam Input (se a Steam não estiver aberta) e ajusta o áudio do controle.</property>
                            <signal name="clicked" handler="on_storm_fix_safe"/>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="btn_storm_copy_launch">
                            <property name="label" translatable="yes">Copiar opções p/ jogos</property>
                            <property name="tooltip-text" translatable="yes">Copia a Opção de Inicialização da Steam (sempre a mesma linha): o launcher do Hefesto decide na hora do jogo se esconde o controle físico — se o Hefesto estiver desligado, o jogo abre normal. Cole em: jogo → Propriedades → Opções de inicialização.</property>
                            <signal name="clicked" handler="on_storm_copy_launch"/>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="btn_steam_apply_launch">
                            <property name="label" translatable="yes">Aplicar aos jogos da Steam</property>
                            <property name="tooltip-text" translatable="yes">Troca as opções antigas do Hefesto pela linha nova do launcher em todos os jogos que as tinham — sem apagar as suas outras opções. Pede a Steam fechada e faz backup antes.</property>
                            <signal name="clicked" handler="on_steam_apply_launch"/>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="btn_proton_lock">
                            <property name="label" translatable="yes">Travar Proton validado</property>
                            <property name="tooltip-text" translatable="yes">Deixa todos os jogos na versão de Proton que o Hefesto validou — assim uma atualização da Steam não muda o comportamento do controle do nada. Pede a Steam fechada e faz backup antes.</property>
                            <signal name="clicked" handler="on_proton_lock"/>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>
                <child>
                  <object class="GtkLabel">
                    <property name="label" translatable="yes">&lt;b&gt;Detalhes técnicos&lt;/b&gt;</property>
                    <property name="use-markup">True</property>
                    <property name="xalign">0</property>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>
                <child>
                  <object class="GtkScrolledWindow" id="daemon_log_scroll">
                    <property name="hscrollbar-policy">never</property>
                    <property name="vscrollbar-policy">automatic</property>
                    <property name="hexpand">True</property>
                    <property name="vexpand">True</property>
                    <style><class name="hefesto-dualsense4unix-card"/></style>
                    <child>
                      <object class="GtkTextView" id="daemon_status_text">
                        <property name="editable">False</property>
                        <property name="monospace">True</property>
                        <property name="cursor-visible">False</property>
                        <property name="wrap-mode">word-char</property>
                        <style><class name="hefesto-dualsense4unix-log"/></style>
                      </object>
                    </child>
                  </object>
                  <packing><property name="expand">True</property><property name="fill">True</property></packing>
                </child>
              </object>
            </child>
            <child type="tab">
              <object class="GtkLabel"><property name="label" translatable="yes">Sistema</property></object>
            </child>

            <!-- Aba Emulação -->
            <child>
              <object class="GtkBox" id="emulation_box">
                <property name="orientation">vertical</property>
                <property name="margin">12</property>
                <property name="spacing">10</property>
                <child>
                  <object class="GtkGrid" id="emulation_info_grid">
                    <property name="row-spacing">6</property>
                    <property name="column-spacing">12</property>
                    <property name="margin">10</property>
                    <property name="halign">start</property>
                    <style><class name="hefesto-dualsense4unix-card"/></style>
                    <child>
                      <object class="GtkLabel"><property name="label" translatable="yes">UINPUT:</property><property name="halign">end</property></object>
                      <packing><property name="left-attach">0</property><property name="top-attach">0</property></packing>
                    </child>
                    <child>
                      <object class="GtkLabel" id="emulation_uinput_label">
                        <property name="label">—</property>
                        <property name="halign">start</property>
                        <property name="use-markup">True</property>
                      </object>
                      <packing><property name="left-attach">1</property><property name="top-attach">0</property></packing>
                    </child>
                    <child>
                      <object class="GtkLabel"><property name="label" translatable="yes">Device:</property><property name="halign">end</property></object>
                      <packing><property name="left-attach">0</property><property name="top-attach">1</property></packing>
                    </child>
                    <child>
                      <object class="GtkLabel" id="emulation_device_name_label">
                        <property name="label" translatable="yes">Microsoft X-Box 360 pad (Hefesto - Dualsense4Unix virtual)</property>
                        <property name="halign">start</property>
                      </object>
                      <packing><property name="left-attach">1</property><property name="top-attach">1</property></packing>
                    </child>
                    <child>
                      <object class="GtkLabel"><property name="label" translatable="yes">VID:PID:</property><property name="halign">end</property></object>
                      <packing><property name="left-attach">0</property><property name="top-attach">2</property></packing>
                    </child>
                    <child>
                      <object class="GtkLabel" id="emulation_vidpid_label">
                        <property name="label" translatable="yes">045E:028E (Xbox 360)</property>
                        <property name="halign">start</property>
                      </object>
                      <packing><property name="left-attach">1</property><property name="top-attach">2</property></packing>
                    </child>
                    <child>
                      <object class="GtkLabel"><property name="label" translatable="yes">Gamepads:</property><property name="halign">end</property></object>
                      <packing><property name="left-attach">0</property><property name="top-attach">3</property></packing>
                    </child>
                    <child>
                      <object class="GtkLabel" id="emulation_js_label">
                        <property name="label">—</property>
                        <property name="halign">start</property>
                        <property name="use-markup">True</property>
                        <property name="selectable">True</property>
                      </object>
                      <packing><property name="left-attach">1</property><property name="top-attach">3</property></packing>
                    </child>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>
                <child>
                  <object class="GtkGrid" id="emulation_combo_grid">
                    <property name="row-spacing">6</property>
                    <property name="column-spacing">12</property>
                    <property name="margin">10</property>
                    <property name="halign">start</property>
                    <style><class name="hefesto-dualsense4unix-card"/></style>
                    <child>
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">&lt;b&gt;Modo jogo&lt;/b&gt;: segure o botão PS para suspender a emulação de mouse/teclado</property>
                        <property name="use-markup">True</property>
                        <property name="halign">start</property>
                      </object>
                      <packing><property name="left-attach">0</property><property name="top-attach">0</property><property name="width">2</property></packing>
                    </child>
                    <child>
                      <object class="GtkLabel"><property name="label" translatable="yes">Próximo:</property><property name="halign">end</property></object>
                      <packing><property name="left-attach">0</property><property name="top-attach">1</property></packing>
                    </child>
                    <child>
                      <object class="GtkLabel" id="emulation_combo_next_label">
                        <property name="label" translatable="yes">PS + D-pad Cima</property>
                        <property name="halign">start</property>
                      </object>
                      <packing><property name="left-attach">1</property><property name="top-attach">1</property></packing>
                    </child>
                    <child>
                      <object class="GtkLabel"><property name="label" translatable="yes">Anterior:</property><property name="halign">end</property></object>
                      <packing><property name="left-attach">0</property><property name="top-attach">2</property></packing>
                    </child>
                    <child>
                      <object class="GtkLabel" id="emulation_combo_prev_label">
                        <property name="label" translatable="yes">PS + D-pad Baixo</property>
                        <property name="halign">start</property>
                      </object>
                      <packing><property name="left-attach">1</property><property name="top-attach">2</property></packing>
                    </child>
                    <child>
                      <object class="GtkLabel"><property name="label" translatable="yes">Buffer:</property><property name="halign">end</property></object>
                      <packing><property name="left-attach">0</property><property name="top-attach">3</property></packing>
                    </child>
                    <child>
                      <object class="GtkLabel" id="emulation_combo_buffer_label">
                        <property name="label">150</property>
                        <property name="halign">start</property>
                      </object>
                      <packing><property name="left-attach">1</property><property name="top-attach">3</property></packing>
                    </child>
                    <child>
                      <object class="GtkLabel"><property name="label" translatable="yes">Passthrough em emulação:</property><property name="halign">end</property></object>
                      <packing><property name="left-attach">0</property><property name="top-attach">4</property></packing>
                    </child>
                    <child>
                      <object class="GtkLabel" id="emulation_passthrough_label">
                        <property name="label" translatable="yes">Não</property>
                        <property name="halign">start</property>
                      </object>
                      <packing><property name="left-attach">1</property><property name="top-attach">4</property></packing>
                    </child>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>
                <child>
                  <object class="GtkBox" id="emulation_btns">
                    <property name="orientation">horizontal</property>
                    <property name="spacing">6</property>
                    <property name="margin-start">10</property>
                    <property name="margin-end">10</property>
                    <child>
                      <object class="GtkButton" id="emulation_test_button">
                        <property name="label" translatable="yes">Testar criação de device virtual</property>
                        <signal name="clicked" handler="on_emulation_test_device"/>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="emulation_refresh_button">
                        <property name="label" translatable="yes">Atualizar</property>
                        <signal name="clicked" handler="on_emulation_refresh"/>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="emulation_open_toml_button">
                        <property name="label" translatable="yes">Ver daemon.toml (referência)</property>
                        <signal name="clicked" handler="on_emulation_open_toml"/>
                      </object>
                    </child>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>
                <child>
                  <object class="GtkBox" id="emulation_gamepad_box">
                    <property name="orientation">horizontal</property>
                    <property name="spacing">6</property>
                    <property name="margin-start">10</property>
                    <property name="margin-end">10</property>
                    <property name="margin-top">8</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">Gamepad p/ jogos:</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="emulation_gamepad_status_label">
                        <property name="label" translatable="yes">—</property>
                        <property name="margin-end">8</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="emulation_gamepad_off_button">
                        <property name="label" translatable="yes">Desligado</property>
                        <property name="tooltip-text" translatable="yes">Volta o controle a controlar o PC (mouse/teclado) — o mesmo que "Controlar o PC" na aba Início. Desliga o gamepad virtual e também sai do "Jogar direto (Sony)".</property>
                        <signal name="clicked" handler="on_emulation_gamepad_off"/>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="emulation_gamepad_dualsense_button">
                        <property name="label" translatable="yes">DualSense (PS)</property>
                        <property name="tooltip-text" translatable="yes">O jogo mostra os botões de PlayStation (X, círculo, quadrado, triângulo) e a vibração funciona. Com o botão 'Copiar opções p/ jogos' (aba Sistema) o controle também não aparece duplicado — layout PS sem o controle dobrado. Atenção: jogos que só entendem controle de Xbox (ex.: Mullet Mad Jack) ignoram esta máscara — neles use "Xbox 360".</property>
                        <signal name="clicked" handler="on_emulation_gamepad_dualsense"/>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="emulation_gamepad_xbox_button">
                        <property name="label" translatable="yes">Xbox 360</property>
                        <property name="tooltip-text" translatable="yes">Máscara Xbox 360: a vibração funciona em jogo e o controle não aparece duplicado. Os jogos mostram prompts de Xbox (A/B/X/Y). É a única máscara que jogos XInput-only entendem; nessa API não existe giroscópio.</property>
                        <signal name="clicked" handler="on_emulation_gamepad_xbox"/>
                      </object>
                    </child>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>

                <!-- MMJ-01 (estudo 2026-07-21): cada jogo "fala uma língua" de
                     controle. Jogos XInput-only (ex.: Mullet Mad Jack) não
                     reconhecem a máscara DualSense — o vpad chega ao jogo, mas
                     a engine ignora o PID Sony. Sem este aviso a usuária vê
                     "controle morto" e caça defeito no lugar errado. -->
                <child>
                  <object class="GtkLabel" id="emulation_gamepad_hint_label">
                    <property name="label" translatable="yes">Qual máscara para qual jogo? Jogos com suporte a DualSense (ex.: Sackboy, Pragmata, Mad King Redemption) funcionam completos com "DualSense (PS)": vibração, giroscópio e lightbar. Jogos que só entendem controle de Xbox (ex.: Mullet Mad Jack) ignoram a máscara DualSense — neles escolha "Xbox 360" (vibração funciona; giroscópio não existe nessa API). Sinal típico de jogo Xbox-only: o controle navega na Steam, mas fica morto dentro do jogo.</property>
                    <property name="wrap">True</property>
                    <property name="xalign">0</property>
                    <property name="margin-start">10</property>
                    <property name="margin-end">10</property>
                    <property name="margin-top">4</property>
                    <style><class name="dim-label"/></style>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>
                <child>
                  <object class="GtkBox" id="emulation_gamemode_box">
                    <property name="orientation">horizontal</property>
                    <property name="spacing">6</property>
                    <property name="margin-start">10</property>
                    <property name="margin-end">10</property>
                    <property name="margin-top">4</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">Modo jogo:</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="emulation_gamemode_status_label">
                        <property name="label" translatable="yes">—</property>
                        <property name="margin-end">8</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="emulation_pause_button">
                        <property name="label" translatable="yes">Modo jogo</property>
                        <property name="tooltip-text" translatable="yes">Suspende a emulação de mouse/teclado (igual ao combo PS+Options). Só faz sentido jogando: em "Controlar o PC" o controle ficaria sem função nenhuma, por isso fica desabilitado nesse modo. Transitório — não sobrevive ao reboot.</property>
                        <signal name="clicked" handler="on_emulation_pause"/>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="emulation_resume_button">
                        <property name="label" translatable="yes">Sair do modo jogo</property>
                        <property name="tooltip-text" translatable="yes">Retoma a emulação de mouse/teclado.</property>
                        <signal name="clicked" handler="on_emulation_resume"/>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="emulation_gamemode_hint_label">
                        <property name="label" translatable="yes"></property>
                        <property name="margin-start">8</property>
                        <property name="wrap">True</property>
                        <property name="xalign">0</property>
                      </object>
                    </child>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>
                <child>
                  <object class="GtkBox" id="emulation_steam_input_box">
                    <property name="orientation">horizontal</property>
                    <property name="spacing">6</property>
                    <property name="margin-start">10</property>
                    <property name="margin-end">10</property>
                    <property name="margin-top">4</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">Steam Input:</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="emulation_steam_input_status_label">
                        <property name="label" translatable="yes">—</property>
                        <property name="margin-end">8</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="emulation_steam_input_check_button">
                        <property name="label" translatable="yes">Verificar</property>
                        <property name="tooltip-text" translatable="yes">Checa se o Steam Input (PSSupport) está ligado — ele conflita com o daemon.</property>
                        <signal name="clicked" handler="on_emulation_steam_input_check"/>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="emulation_steam_input_disable_button">
                        <property name="label" translatable="yes">Desligar Steam Input</property>
                        <property name="tooltip-text" translatable="yes">Desliga o Steam Input PSSupport (fecha e reabre a Steam). Evita o conflito com o daemon.</property>
                        <signal name="clicked" handler="on_emulation_steam_input_disable"/>
                      </object>
                    </child>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>
                <child>
                  <object class="GtkBox" id="emulation_mic_box">
                    <property name="orientation">horizontal</property>
                    <property name="spacing">6</property>
                    <property name="margin-start">10</property>
                    <property name="margin-end">10</property>
                    <property name="margin-top">4</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">Microfone do DualSense:</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="emulation_mic_status_label">
                        <property name="label" translatable="yes">—</property>
                        <property name="margin-end">8</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="emulation_mic_on_button">
                        <property name="label" translatable="yes">Ligar</property>
                        <property name="tooltip-text" translatable="yes">Libera o mic embutido do DualSense (para jogos que pedem mic). O quirk segura o storm.</property>
                        <signal name="clicked" handler="on_emulation_mic_on"/>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="emulation_mic_off_button">
                        <property name="label" translatable="yes">Desligar</property>
                        <property name="tooltip-text" translatable="yes">Suprime o mic do DualSense (não vira microfone padrão, sem spam).</property>
                        <signal name="clicked" handler="on_emulation_mic_off"/>
                      </object>
                    </child>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>
                <child>
                  <object class="GtkLabel" id="emulation_hint">
                    <property name="label" translatable="yes">&lt;i&gt;Como o jogo vê o controle: &lt;b&gt;DualSense&lt;/b&gt; mostra os botões de PlayStation e vibra. &lt;b&gt;Xbox 360&lt;/b&gt; serve para jogos que só entendem controle de Xbox. Enquanto isso, o Hefesto é quem fala com o controle.&lt;/i&gt;</property>
                    <property name="use-markup">True</property>
                    <property name="xalign">0</property>
                    <property name="wrap">True</property>
                    <property name="margin-start">10</property>
                    <property name="margin-end">10</property>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>
              </object>
            </child>
            <child type="tab">
              <object class="GtkLabel"><property name="label" translatable="yes">Emulação</property></object>
            </child>

            <!-- Aba Mouse (somente emulação de mouse — Teclado é aba separada) -->
            <child>
              <object class="GtkBox" id="tab_mouse">
                <property name="orientation">vertical</property>
                <property name="margin">12</property>
                <property name="spacing">10</property>

                <child>
                  <object class="GtkBox">
                    <property name="orientation">horizontal</property>
                    <property name="spacing">10</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">&lt;b&gt;Emular mouse+teclado&lt;/b&gt;</property>
                        <property name="use-markup">True</property>
                        <property name="xalign">0</property>
                      </object>
                      <packing><property name="expand">True</property></packing>
                    </child>
                    <child>
                      <object class="GtkSwitch" id="mouse_emulation_toggle">
                        <property name="active">False</property>
                        <!-- HARM-05: nasce fechado e só abre quando o daemon
                             confirmar o modo "Controlar o PC" (o refresh da aba
                             é assíncrono). Oferecê-lo antes de saber o modo é
                             oferecer às cegas o clique que derruba o vpad. -->
                        <property name="sensitive">False</property>
                        <signal name="state-set" handler="on_mouse_toggle_set"/>
                      </object>
                      <packing><property name="expand">False</property></packing>
                    </child>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>

                <!-- HARM-05: a razão de o switch estar bloqueado, em texto simples.
                     Fora do modo "Controlar o PC" ligar o mouse derrubava o vpad e
                     os jogadores do co-op SEM AVISO, no meio do jogo. -->
                <child>
                  <object class="GtkLabel" id="mouse_mode_hint_label">
                    <property name="label"></property>
                    <property name="wrap">True</property>
                    <property name="xalign">0</property>
                    <property name="no-show-all">True</property>
                    <style><class name="dim-label"/></style>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>

                <child>
                  <object class="GtkLabel" id="mouse_uinput_status_label">
                    <property name="label">—</property>
                    <property name="use-markup">True</property>
                    <property name="xalign">0</property>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>

                <child>
                  <object class="GtkSeparator"><property name="orientation">horizontal</property></object>
                  <packing><property name="expand">False</property></packing>
                </child>

                <child>
                  <object class="GtkGrid" id="mouse_speed_grid">
                    <property name="row-spacing">8</property>
                    <property name="column-spacing">10</property>
                    <style><class name="hefesto-dualsense4unix-card"/></style>
                    <child>
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">Velocidade do cursor:</property>
                        <property name="xalign">1</property>
                      </object>
                      <packing><property name="left-attach">0</property><property name="top-attach">0</property></packing>
                    </child>
                    <child>
                      <object class="GtkScale" id="mouse_speed_scale">
                        <property name="adjustment">mouse_speed_adj</property>
                        <property name="digits">0</property>
                        <property name="draw-value">True</property>
                        <property name="value-pos">right</property>
                        <property name="hexpand">True</property>
                        <signal name="value-changed" handler="on_mouse_speed_changed"/>
                      </object>
                      <packing><property name="left-attach">1</property><property name="top-attach">0</property></packing>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">Velocidade da rolagem:</property>
                        <property name="xalign">1</property>
                      </object>
                      <packing><property name="left-attach">0</property><property name="top-attach">1</property></packing>
                    </child>
                    <child>
                      <object class="GtkScale" id="mouse_scroll_speed_scale">
                        <property name="adjustment">mouse_scroll_speed_adj</property>
                        <property name="digits">0</property>
                        <property name="draw-value">True</property>
                        <property name="value-pos">right</property>
                        <property name="hexpand">True</property>
                        <signal name="value-changed" handler="on_mouse_scroll_speed_changed"/>
                      </object>
                      <packing><property name="left-attach">1</property><property name="top-attach">1</property></packing>
                    </child>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>

                <child>
                  <object class="GtkSeparator"><property name="orientation">horizontal</property></object>
                  <packing><property name="expand">False</property></packing>
                </child>

                <child>
                  <object class="GtkFrame" id="mouse_mapping_frame">
                    <style><class name="hefesto-dualsense4unix-card"/></style>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">6</property>
                        <property name="margin">10</property>
                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">&lt;b&gt;Mapeamento&lt;/b&gt;</property>
                            <property name="use-markup">True</property>
                            <property name="xalign">0</property>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>
                        <child>
                          <object class="GtkGrid" id="mouse_mapping_grid">
                            <property name="row-spacing">4</property>
                            <property name="column-spacing">8</property>
                            <child>
                              <object class="GtkLabel"><property name="label" translatable="yes">Cruz (X) ou L2</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">0</property><property name="top-attach">0</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">→</property><property name="xalign">0.5</property></object>
                              <packing><property name="left-attach">1</property><property name="top-attach">0</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label" translatable="yes">Botão esquerdo</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">2</property><property name="top-attach">0</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label" translatable="yes">Triângulo (&#9651;) ou R2</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">0</property><property name="top-attach">1</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">→</property><property name="xalign">0.5</property></object>
                              <packing><property name="left-attach">1</property><property name="top-attach">1</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label" translatable="yes">Botão direito</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">2</property><property name="top-attach">1</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label" translatable="yes">R3 (clique no analógico direito)</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">0</property><property name="top-attach">2</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">→</property><property name="xalign">0.5</property></object>
                              <packing><property name="left-attach">1</property><property name="top-attach">2</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label" translatable="yes">Botão do meio</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">2</property><property name="top-attach">2</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label" translatable="yes">Círculo (&#9675;)</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">0</property><property name="top-attach">3</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">→</property><property name="xalign">0.5</property></object>
                              <packing><property name="left-attach">1</property><property name="top-attach">3</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label" translatable="yes">Enter</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">2</property><property name="top-attach">3</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label" translatable="yes">Quadrado (□)</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">0</property><property name="top-attach">4</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">→</property><property name="xalign">0.5</property></object>
                              <packing><property name="left-attach">1</property><property name="top-attach">4</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label" translatable="yes">Esc</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">2</property><property name="top-attach">4</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label" translatable="yes">D-pad (↑↓←→)</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">0</property><property name="top-attach">5</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">→</property><property name="xalign">0.5</property></object>
                              <packing><property name="left-attach">1</property><property name="top-attach">5</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label" translatable="yes">Setas do teclado</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">2</property><property name="top-attach">5</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label" translatable="yes">Analógico esquerdo</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">0</property><property name="top-attach">6</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">→</property><property name="xalign">0.5</property></object>
                              <packing><property name="left-attach">1</property><property name="top-attach">6</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label" translatable="yes">Movimento do cursor</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">2</property><property name="top-attach">6</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label" translatable="yes">Analógico direito</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">0</property><property name="top-attach">7</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label">→</property><property name="xalign">0.5</property></object>
                              <packing><property name="left-attach">1</property><property name="top-attach">7</property></packing>
                            </child>
                            <child>
                              <object class="GtkLabel"><property name="label" translatable="yes">Rolagem vertical e horizontal</property><property name="xalign">0</property></object>
                              <packing><property name="left-attach">2</property><property name="top-attach">7</property></packing>
                            </child>
                          </object>
                          <packing><property name="expand">False</property></packing>
                        </child>
                      </object>
                    </child>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>

                <child>
                  <object class="GtkLabel">
                    <property name="label" translatable="yes">&lt;i&gt;Útil para navegar o desktop, apresentações e jogos que só aceitam mouse/teclado. Requer módulo uinput carregado e regra udev (ver aba Emulação).&lt;/i&gt;</property>
                    <property name="use-markup">True</property>
                    <property name="xalign">0</property>
                    <property name="wrap">True</property>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>
              </object>
            </child>
            <child type="tab">
              <object class="GtkLabel"><property name="label" translatable="yes">Mouse</property></object>
            </child>

            <!-- Aba Teclado (FEAT-KEYBOARD-UI-01 separada de Mouse para
                 enxugar min-size do notebook — antes ambas viviam numa única
                 aba "Mouse e Teclado" e a soma de mapeamento + treeview
                 inflava a altura natural de todas as outras abas). -->
            <child>
              <object class="GtkBox" id="tab_keyboard">
                <property name="orientation">vertical</property>
                <property name="margin">12</property>
                <property name="spacing">10</property>
                <child>
                  <object class="GtkLabel">
                    <property name="label" translatable="yes">&lt;b&gt;Atalhos de teclado do perfil ativo&lt;/b&gt;</property>
                    <property name="use-markup">True</property>
                    <property name="xalign">0</property>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>
                <child>
                  <object class="GtkLabel" id="key_bindings_legend">
                    <property name="label" translatable="yes">Formato: KEY_* (ex: KEY_C, KEY_ENTER) ou __OPEN_OSK__/__CLOSE_OSK__. Combos com '+' (ex: KEY_LEFTALT+KEY_TAB).</property>
                    <property name="use-markup">True</property>
                    <property name="xalign">0</property>
                    <property name="wrap">True</property>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>
                <child>
                  <object class="GtkScrolledWindow">
                    <property name="visible">True</property>
                    <property name="can-focus">True</property>
                    <property name="shadow-type">in</property>
                    <property name="min-content-height">160</property>
                    <child>
                      <object class="GtkTreeView" id="key_bindings_treeview">
                        <property name="visible">True</property>
                        <property name="can-focus">True</property>
                        <property name="headers-visible">True</property>
                        <property name="rules-hint">True</property>
                      </object>
                    </child>
                  </object>
                  <packing><property name="expand">True</property><property name="fill">True</property></packing>
                </child>
                <child>
                  <object class="GtkBox" id="key_bindings_button_row">
                    <property name="orientation">horizontal</property>
                    <property name="spacing">6</property>
                    <property name="homogeneous">False</property>
                    <child>
                      <object class="GtkButton" id="key_binding_add_btn">
                        <property name="label" translatable="yes">Adicionar</property>
                        <signal name="clicked" handler="on_key_binding_add"/>
                      </object>
                      <packing><property name="expand">False</property></packing>
                    </child>
                    <child>
                      <object class="GtkButton" id="key_binding_remove_btn">
                        <property name="label" translatable="yes">Remover</property>
                        <signal name="clicked" handler="on_key_binding_remove"/>
                      </object>
                      <packing><property name="expand">False</property></packing>
                    </child>
                    <child>
                      <object class="GtkButton" id="key_binding_restore_btn">
                        <property name="label" translatable="yes">Restaurar defaults</property>
                        <signal name="clicked" handler="on_key_binding_restore_defaults"/>
                      </object>
                      <packing><property name="expand">False</property></packing>
                    </child>
                  </object>
                  <packing><property name="expand">False</property></packing>
                </child>
              </object>
            </child>
            <child type="tab">
              <object class="GtkLabel"><property name="label" translatable="yes">Teclado</property></object>
            </child>

          </object>
          <packing>
            <property name="expand">True</property>
            <property name="fill">True</property>
          </packing>
        </child>

        <!-- Rodape: statusbar + botoes de acao global -->
        <child>
          <object class="GtkBox" id="footer_box">
            <property name="orientation">horizontal</property>
            <property name="spacing">6</property>
            <property name="margin-start">4</property>
            <property name="margin-end">6</property>
            <property name="margin-top">2</property>
            <property name="margin-bottom">2</property>

            <!-- Statusbar ocupa espaco flexivel a esquerda -->
            <child>
              <object class="GtkStatusbar" id="status_bar">
                <property name="hexpand">True</property>
              </object>
              <packing>
                <property name="expand">True</property>
                <property name="fill">True</property>
              </packing>
            </child>

            <!-- Caixa de botoes alinhada a direita. GtkBox horizontal: os 4
                 botoes (Aplicar/Salvar/Importar/Restaurar) sao filhos DIRETOS,
                 sempre visiveis. FIX-GUI-COSMIC-REMEDIATION-01 (F1): o GtkFlowBox
                 anterior dropava 3 dos 4 botoes (Negative content width) — só
                 "Aplicar" renderizava. BUG-FOOTER-CORTADO. -->
            <child>
              <object class="GtkBox" id="footer_buttons_box">
                <property name="orientation">horizontal</property>
                <property name="spacing">6</property>
                <property name="valign">center</property>
                <property name="halign">end</property>

                <child>
                  <object class="GtkButton" id="btn_footer_apply">
                    <property name="label" translatable="yes">Aplicar</property>
                    <property name="tooltip-text" translatable="yes">Envia toda a configuração (gatilhos, LEDs, rumble, mouse) ao controle</property>
                    <signal name="clicked" handler="on_apply_draft"/>
                    <style><class name="btn-apply"/></style>
                  <child internal-child="accessible">
                    <object class="AtkObject">
                      <property name="AtkObject::accessible-name" translatable="yes">Aplicar todas as configuracoes</property>
                      <property name="AtkObject::accessible-description" translatable="yes">Envia gatilhos LEDs rumble e mouse ao controle</property>
                    </object>
                  </child>
                  </object>
                </child>

                <child>
                  <object class="GtkButton" id="btn_footer_save_profile">
                    <property name="label" translatable="yes">Salvar Perfil</property>
                    <property name="tooltip-text" translatable="yes">Salva o estado atual como um perfil nomeado</property>
                    <signal name="clicked" handler="on_save_profile"/>
                    <style><class name="btn-save"/></style>
                  </object>
                </child>

                <child>
                  <object class="GtkButton" id="btn_footer_import">
                    <property name="label" translatable="yes">Importar</property>
                    <property name="tooltip-text" translatable="yes">Carrega um perfil de arquivo .json</property>
                    <signal name="clicked" handler="on_import_profile"/>
                    <style><class name="btn-import"/></style>
                  </object>
                </child>

                <child>
                  <object class="GtkButton" id="btn_footer_restore_default">
                    <property name="label" translatable="yes">Restaurar Default</property>
                    <property name="tooltip-text" translatable="yes">Restaura o perfil 'Meu Perfil' ao estado original</property>
                    <signal name="clicked" handler="on_restore_default"/>
                    <style><class name="btn-restore"/></style>
                  </object>
                </child>

              </object>
              <packing><property name="expand">False</property></packing>
            </child>

          </object>
          <packing><property name="expand">False</property></packing>
        </child>

      </object>
    </child>
  </object>
</interface>
