#!/bin/bash
set -e

case "$1" in
    remove|upgrade|deconfigure)
        # Sinaliza processos da GUI e do daemon para encerrar graciosamente.
        # Nota: systemd --user e por-usuario; nao e possivel fazer
        # systemctl --user stop como root. O usuario deve executar
        # systemctl --user disable --now hefesto.service antes de remover,
        # ou o postrm emitira aviso.
        pkill -TERM -f 'hefesto\.app\.main' 2>/dev/null || true
        pkill -TERM -f 'hefesto-dualsense4unix daemon start' 2>/dev/null || true
        ;;
esac

case "$1" in
    remove)
        # BROKER-01 (Onda S — achados #2/#8, licao 6/#21): a unit ROOT do
        # broker (hefesto-hidraw-broker.{socket,service}) e instalada FORA do
        # manifesto do dpkg (render por-maquina via install-host-udev.sh) —
        # sem este bloco, apt remove/purge deixava um servico root orfao
        # HABILITADO para sempre. disable --now dispara o ExecStopPost
        # --restore-all-and-exit da propria unit; o belt explicito repete o
        # restore ANTES de o dpkg apagar qualquer arquivo (nenhum hidraw
        # fisico pode ficar 0600 root sem dono). Mesma sequencia do
        # pre_remove (Arch) e do %preun (Fedora).
        if command -v systemctl >/dev/null 2>&1 \
                && { systemctl is-enabled hefesto-hidraw-broker.socket >/dev/null 2>&1 \
                     || systemctl is-active hefesto-hidraw-broker.service >/dev/null 2>&1 \
                     || [ -e /etc/systemd/system/hefesto-hidraw-broker.socket ]; }; then
            systemctl disable --now hefesto-hidraw-broker.socket \
                hefesto-hidraw-broker.service 2>/dev/null || true
            if [ -x /usr/local/lib/hefesto-dualsense4unix/hefesto-hidraw-broker ]; then
                /usr/local/lib/hefesto-dualsense4unix/hefesto-hidraw-broker \
                    --restore-all-and-exit 2>/dev/null || true
            fi
            rm -f /etc/systemd/system/hefesto-hidraw-broker.service \
                  /etc/systemd/system/hefesto-hidraw-broker.socket
            systemctl daemon-reload 2>/dev/null || true
        fi
        # Onda T (corretor, achado #9): o modulo DKMS hefesto-hid-nintendo e
        # construido FORA do manifesto do dpkg (install-host-udev.sh) — sem
        # este bloco, apt remove deixava o modulo patchado registrado no
        # DKMS vencendo o in-tree para sempre (mesma logica do broker acima).
        # NUNCA descarrega modulo em uso (controles conectados cairiam); o
        # in-tree volta sozinho no proximo boot (depmod ja refeito).
        if command -v dkms >/dev/null 2>&1 \
                && dkms status hefesto-hid-nintendo 2>/dev/null | grep -q .; then
            dkms status hefesto-hid-nintendo 2>/dev/null \
                | sed -n 's|^hefesto-hid-nintendo/\([^,: ]*\).*|\1|p' | sort -u \
                | while read -r _v; do
                    [ -n "${_v}" ] || continue
                    dkms remove "hefesto-hid-nintendo/${_v}" --all 2>/dev/null || true
                    rm -rf "/usr/src/hefesto-hid-nintendo-${_v}"
                done
            depmod -a 2>/dev/null || true
        fi
        rm -f /etc/modprobe.d/hefesto-hid-nintendo.conf
        # Onda W: o modulo DKMS hefesto-rtw88-usb tambem nasce FORA do
        # manifesto do dpkg (install-host-udev.sh) — mesma simetria: sem
        # este bloco, apt remove deixava o patchado registrado no DKMS
        # vencendo o in-tree para sempre. NUNCA descarrega modulo em uso
        # (o WiFi cairia); o in-tree volta sozinho no proximo boot.
        if command -v dkms >/dev/null 2>&1 \
                && dkms status hefesto-rtw88-usb 2>/dev/null | grep -q .; then
            dkms status hefesto-rtw88-usb 2>/dev/null \
                | sed -n 's|^hefesto-rtw88-usb/\([^,: ]*\).*|\1|p' | sort -u \
                | while read -r _v; do
                    [ -n "${_v}" ] || continue
                    dkms remove "hefesto-rtw88-usb/${_v}" --all 2>/dev/null || true
                    rm -rf "/usr/src/hefesto-rtw88-usb-${_v}"
                done
            depmod -a 2>/dev/null || true
            # belt (simetrico ao uninstall.sh nativo): se o patchado ainda
            # esta CARREGADO, desarma o reset agressivo a quente ate o boot —
            # deteccao/silenciamento seguem; o modulo em uso nunca e
            # descarregado (o WiFi cairia).
            if [ -e /sys/module/rtw88_usb/parameters/hang_reset ]; then
                printf '0' > /sys/module/rtw88_usb/parameters/hang_reset 2>/dev/null || true
            fi
        fi
        ;;
esac

exit 0
